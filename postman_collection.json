							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if(jsonData.token){",
									"    pm.environment.set(\"token\", jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"name\": \"Saurabh\",\r\n    \"email\": \"saurabh@example.com\",\r\n    \"phone\": \"9998887776\",\r\n    \"password\": \"password123\"\r\n}",
